{
  "project": {
    "name": "MBGA_COVID_Forecast_FullFeatures",
    "version": "2.0.0",
    "description": "完整特征集的MABG两阶段训练"
  },
  "data": {
    "sequence_length": 4,
    "covid_start_date": "2020-01-01",
    "validation_ratio": 0.15,
    "test_ratio": 0.15
  },
  "features": {
    "use_seasonal": true,
    "use_trends": true,
    "trends_lags": [1, 2],
    "target_col": "value",
    "baseline_features": ["flu_Trends"],
    "covid_features": ["flu_Trends", "COVID_19_Trends", "fever_Trends", "loss_of_smell_Trends"]
  },
  "model": {
    "type": "simple_gru",
    "input_size": 1,
    "hidden_size": 32,
    "num_layers": 1,
    "dropout": 0.5,
    "attention_heads": 4,
    "reduction": 8,
    "covid_model": {
      "type": "mabg",
      "hidden_size": 64,
      "num_layers": 2,
      "dropout": 0.3,
      "learning_rate": 0.0005,
      "epochs": 150,
      "patience": 30,
      "batch_size": 8
    }
  },
  "training": {
    "epochs": 100,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "batch_size": 16,
    "patience": 20
  },
  "paths": {
    "model_path": "trained_models/",
    "results_path": "outputs/"
  }
}
