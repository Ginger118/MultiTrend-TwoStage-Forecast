{
  "experiment_name": "Hungary Tuned v2 - Larger Model + Regularization",
  "description": "增加模型容量，加强正则化",
  "region": "Hungary",
  "data": {
    "resp_file": "Cleaned_RESP.csv",
    "flu_file": "Cleaned_Flu_RSV_Combined.csv",
    "covid_start_date": "2020-01-01",
    "trends_files": ["flu_Trends", "COVID_19_Trends", "fever_Trends", "loss_of_smell_Trends"]
  },
  "features": {
    "baseline_features": ["flu_Trends"],
    "covid_features": ["flu_Trends", "COVID_19_Trends", "fever_Trends"],
    "lags": [1, 2]
  },
  "model": {
    "type": "simple_gru",
    "hidden_size": 48,
    "num_layers": 1,
    "dropout": 0.4,
    "covid_model": {
      "type": "multi_trend_attention",
      "num_trends": 3,
      "trend_dim": 4,
      "encoder_hidden": 32,
      "num_heads": 4,
      "fusion_hidden": 48,
      "dropout": 0.3,
      "learning_rate": 0.001,
      "epochs": 250,
      "patience": 35,
      "weight_decay": 0.001,
      "batch_size": 24
    }
  },
  "training": {
    "epochs": 120,
    "batch_size": 24,
    "learning_rate": 0.0008,
    "patience": 20,
    "sequence_length": 6
  },
  "features_config": {
    "use_seasonal_features": true
  }
}
