{
  "project": {
    "name": "MBGA_COVID_Forecast_Minimal",
    "version": "2.0.0",
    "description": "最小特征集baseline测试"
  },
  "data": {
    "sequence_length": 4,
    "covid_start_date": "2020-01-01",
    "validation_ratio": 0.15,
    "test_ratio": 0.15
  },
  "features": {
    "use_seasonal": true,
    "use_trends": true,
    "trends_lags": [1, 2],
    "target_col": "value",
    "baseline_features": ["flu_Trends"],
    "covid_features": ["flu_Trends"]
  },
  "model": {
    "type": "simple_gru",
    "input_size": 1,
    "hidden_size": 32,
    "num_layers": 1,
    "dropout": 0.5,
    "covid_model": {
      "type": "simple_gru",
      "hidden_size": 16,
      "num_layers": 1,
      "dropout": 0.6,
      "learning_rate": 0.001,
      "epochs": 100,
      "patience": 25
    }
  },
  "training": {
    "epochs": 100,
    "learning_rate": 0.001,
    "weight_decay": 0.01,
    "batch_size": 16,
    "patience": 20
  },
  "paths": {
    "model_path": "trained_models/",
    "results_path": "outputs/"
  }
}
