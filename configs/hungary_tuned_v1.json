{
  "experiment_name": "Hungary Tuned v1 - Lower LR + More Patience",
  "description": "降低学习率，增加patience，尝试更保守的训练策略",
  "region": "Hungary",
  "data": {
    "resp_file": "Cleaned_RESP.csv",
    "flu_file": "Cleaned_Flu_RSV_Combined.csv",
    "covid_start_date": "2020-01-01",
    "trends_files": ["flu_Trends", "COVID_19_Trends", "fever_Trends", "loss_of_smell_Trends"]
  },
  "features": {
    "baseline_features": ["flu_Trends"],
    "covid_features": ["flu_Trends", "COVID_19_Trends", "fever_Trends"],
    "lags": [1, 2, 3]
  },
  "model": {
    "type": "simple_gru",
    "hidden_size": 32,
    "num_layers": 1,
    "dropout": 0.3,
    "covid_model": {
      "type": "multi_trend_attention",
      "num_trends": 3,
      "trend_dim": 4,
      "encoder_hidden": 24,
      "num_heads": 3,
      "fusion_hidden": 32,
      "dropout": 0.2,
      "learning_rate": 0.0005,
      "epochs": 300,
      "patience": 40,
      "weight_decay": 0.0001,
      "batch_size": 16
    }
  },
  "training": {
    "epochs": 150,
    "batch_size": 16,
    "learning_rate": 0.0005,
    "patience": 25,
    "sequence_length": 6
  },
  "features_config": {
    "use_seasonal_features": true
  }
}
